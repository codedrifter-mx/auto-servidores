{
  "productName": "Auto Servidores",
  "version": "2.0.1",
  "identifier": "mx.declaranet.auto-servidores",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../src/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auto Servidores",
        "width": 1150,
        "height": 750,
        "minWidth": 950,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../config.toml"
    ]
  }
}
